# Copy to `.env` and fill in values. Never commit real `.env` files.
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=sqlite:///db.sqlite3
REGISTER_AUTO_VERIFY=True

# Email (required by settings; use dummy for local)
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

FRONTEND_URL=http://localhost:4200
REDIS_URL=redis://127.0.0.1:6379/1

# Payments (see docs/PAYMENTS_AND_PROMOS.md)
PAYMENT_PROVIDER=mock
PAYMENT_WEBHOOK_SECRET=dev-webhook-secret-change-me
ENABLE_PAYMENT_WEBHOOK_SIMULATION=True

# Stripe (set PAYMENT_PROVIDER=stripe and add keys from Stripe Dashboard)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
